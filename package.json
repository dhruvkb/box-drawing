{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "beam",
  "description": "A monorepo of Raycast extensions.",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "fix-lint": "pnpm -r fix-lint",
    "dev": "pnpm -F box-drawing dev",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
